DOCKER_IMAGE=your-dockerhub-user/ticket-queue:latest
DD_API_KEY=replace-with-datadog-api-key
DD_SITE=us5.datadoghq.com
DD_ENV=prod
DD_VERSION=latest
REDIS_HOST=ticket-managed-redis.southeastasia.redis.azure.net
REDIS_PORT=10000
REDIS_CLUSTER_NODES=rediss://ticket-managed-redis.southeastasia.redis.azure.net:10000
REDIS_USERNAME=default
REDIS_PASSWORD=replace-with-managed-redis-access-key
REDIS_SSL_ENABLED=true
JWT_SECRET=replace-with-core-access-token-secret-32-byte-minimum
JWT_ISSUER=ticket
JWT_ACCESS_TOKEN_EXPIRATION_SECONDS=1800
QUEUE_TOKEN_SECRET=replace-with-32-byte-minimum-secret
ADMISSION_TOKEN_SECRET_KEY=replace-with-32-byte-minimum-secret
APP_QUEUE_SCHEDULER_ENABLED=true
