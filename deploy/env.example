DOCKER_IMAGE=your-dockerhub-user/ticket-queue:latest
INTERNAL_AUTH_SECRET_KEY=replace-with-32-byte-minimum-secret
QUEUE_TOKEN_SECRET=replace-with-32-byte-minimum-secret
ADMISSION_TOKEN_SECRET_KEY=replace-with-32-byte-minimum-secret
APP_QUEUE_PUBLIC_STATE_OUTPUT_DIRECTORY=/app/build/public-state
APP_QUEUE_PUBLIC_STATE_PATH_TEMPLATE=queue-state/performances/{performanceId}.json
APP_QUEUE_SCHEDULER_ENABLED=true
